#this program takes the car data csv file and converts it into 4 seperate plots in 1 figure that shows each of four predictors and their correlation to price, such as car engine displacement,car top speed, car maintenance intervals and car mileage
from scipy import stats
import pandas as pd
import matplotlib.pyplot as plt
import numpy as np
df= pd.read_csv('car_data.csv')
#df.columns=['car_price','car_year','car_mileage','car_maintenance_interval','car_engine_displacement','car_weight','car_seats','car_top_speed']
Linear_regression=stats.linregress(x=df.car_engine_displacement,y=df.car_price)
df.car_top_speed=df.car_top_speed.floordiv(100)
engineDisplacePredict=Linear_regression.slope*2.5+Linear_regression.intercept
plt.subplot(1,4,1)
enginePlot=plt.plot(df.car_engine_displacement,df.car_price,'o')
plt.title("carengidisplace")

print("This is the price of a car with 2500 engine displacement:")
print(engineDisplacePredict)    
plt.subplot(1,4,2)
plt.title("cartopspeed")
topSpeedPredict=stats.linregress(x=df.car_top_speed,y=df.car_price)
topSpeedValue=topSpeedPredict.slope*189+topSpeedPredict.intercept
topSpeedPlot=plt.plot(df.car_top_speed,df.car_price,'o')

plt.subplot(1,4,3)
print("this is the Price of a car that can go up to 189mph")
print(topSpeedValue)
plt.plot(df.car_mileage,df.car_price,'o')
plt.title("Car Mile")

plt.subplot(1,4,4)
milePredict=stats.linregress(x=df.car_mileage,y=df.car_price)
mileValue=milePredict.slope*108567+milePredict.intercept
print("this is the price of a car with 108,567 miles on it")
print(mileValue)
df.car_maintenance_interval=df.car_maintenance_interval.floordiv(100)
carMaintenancePredict=stats.linregress(x=df.car_maintenance_interval,y=df.car_price)
carMaintenanceValue=carMaintenancePredict.slope*15000+carMaintenancePredict.intercept
print("this is the Price of a car that has maintenance intervals every 15,000 miles")
print(carMaintenanceValue)
plt.plot(df.car_maintenance_interval,df.car_price,'o')
plt.title("Car Maint Interval")
plt.show()
